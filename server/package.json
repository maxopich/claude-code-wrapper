{
  "name": "@cebab/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "predev": "node ../scripts/predev-server.mjs",
    "dev": "tsx watch --env-file-if-exists=../.env src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file-if-exists=../.env dist/index.js",
    "smoke": "tsx --env-file-if-exists=../.env src/smoke.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.201",
    "@cebab/shared": "*",
    "better-sqlite3": "^12.11.1",
    "express": "^5.2.1",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.0",
    "@types/node": "^26.1.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  }
}
