; Block npm lifecycle scripts (preinstall / install / postinstall) repo-wide.
;
; Cebab bus workers and the orchestrator run with --permission-mode
; bypassPermissions, so a malicious transitive postinstall script lands
; as direct RCE on an operator's machine. The legitimate native build
; (better-sqlite3) is re-enabled explicitly via `npm rebuild
; better-sqlite3 --foreground-scripts` in CI and dev setup.
ignore-scripts=true
