; Block npm lifecycle scripts (preinstall / install / postinstall) repo-wide.
;
; Cebab bus workers and the orchestrator run with --permission-mode
; bypassPermissions, so a malicious transitive postinstall script lands
; as direct RCE on an operator's machine. The legitimate native build
; (better-sqlite3) is re-enabled explicitly via `npm rebuild
; better-sqlite3 --foreground-scripts` in CI and dev setup.
ignore-scripts=true

; Supply-chain hardening: refuse to resolve any version published < 7 days ago.
; A freshly-published (possibly account-takeover / malicious) release must age
; a week before npm will install it — the window in which most poisoned
; publishes are caught and yanked. `npm ci` installs the lockfile verbatim, so
; this only gates fresh *resolution* (`npm install`, transitive bumps); it pairs
; with the dependabot `cooldown` in .github/dependabot.yml.
min-release-age=7
