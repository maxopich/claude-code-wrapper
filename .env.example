# Default workspace root used when nothing is set in the UI. The browser-side
# Settings panel writes to ~/.cebab/cebab.sqlite which always wins. This is
# only the fallback for fresh installs and scripted launches.
WORKSPACE_ROOT=~/Claude_Space

# Set to 1 to replay fixtures/*.jsonl instead of spawning real `claude`.
MOCK=0

# WebSocket server port. The web client connects to this port, and so does
# vite's dev-mode proxy (see web/vite.config.ts).
PORT=4319

# Hard cap on agent turns per user message. Prevents runaway loops.
# MAX_TURNS=50

# Comma-separated extra Origins permitted to open the WS, e.g. when serving
# the built bundle from a non-default port.
# CEBAB_ALLOWED_ORIGINS=http://127.0.0.1:8080,http://localhost:8080

# Optional: override the port the browser dials. Defaults to PORT above.
# Useful if you front the server with a reverse proxy on a different port.
# VITE_SERVER_PORT=4319
