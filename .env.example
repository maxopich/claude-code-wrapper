# Absolute or ~-prefixed path to a directory whose subdirectories are agent
# projects. Each subdirectory becomes a sidebar entry; the agent runs with that
# directory as cwd, so its CLAUDE.md / .claude/skills / .claude/mcp.json all
# auto-load.
WORKSPACE_ROOT=~/Claude_Space

# Set to 1 to replay fixtures/*.jsonl instead of spawning real `claude`.
MOCK=0

# WebSocket server port. The web client connects to this port, and so does
# vite's dev-mode proxy (see web/vite.config.ts).
PORT=4319

# Optional: override the port the browser dials. Defaults to PORT above.
# Useful if you front the server with a reverse proxy on a different port.
# VITE_SERVER_PORT=4319
